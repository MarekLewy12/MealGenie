generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Diet {
  NONE
  VEGETARIAN
  VEGAN
  KETO
  PALEO
  GLUTEN_FREE
}

enum CookingSkill {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum KitchenEquipment {
  OVEN
  STOVE
  MICROWAVE
  BLENDER
  AIR_FRYER
  SLOW_COOKER
  GRILL
}

enum BudgetLevel {
  CHEAP
  MODERATE
  EXPENSIVE
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  name         String
  passwordHash String
  status       String       @default("ACTIVE")
  createdAt    DateTime     @default(now())
  preferences  Preferences?
}

model Preferences {
  id                  String             @id @default(uuid())
  diet                Diet
  allergies           String[]
  favCuisines         String[]
  dislikedIngredients String[]
  cookingSkill        CookingSkill
  kitchenEquipment    KitchenEquipment[] @default([])
  useThermomix        Boolean            @default(false)
  budget              BudgetLevel
  updatedAt           DateTime           @updatedAt
  user                User               @relation(fields: [userId], references: [id])
  userId              String             @unique @map("user_id")
}
